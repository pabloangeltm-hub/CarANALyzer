# ============================================================
# .env.example — copy to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Google (OAuth credentials live in credentials.json / token.json) ---
GOOGLE_SHEET_ID=
GOOGLE_SLIDES_ID=

# --- Proxy ---
# Format: http://user:password@host:port  or  socks5://host:port
PROXY_URL=

# --- Database ---
# Format: postgresql://user:password@host:port/dbname
DB_CONNECTION_STRING=

# --- Telegram Alerts ---
# Create a bot via @BotFather, get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Auth (JWT) ---
# At least 32 random bytes; generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# --- Stripe ---
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret from Stripe dashboard or Stripe CLI (`stripe listen --print-secret`)
STRIPE_WEBHOOK_SECRET=whsec_...
# Run tools/api/setup_stripe_products.py to generate these values
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...
# Public base URL used to build Stripe redirect URLs (no trailing slash)
AGARTHA_PUBLIC_URL=https://your-domain.com
# Stripe SDK retry count on network errors (default 2)
STRIPE_MAX_NETWORK_RETRIES=2

# --- Resend (transactional email) ---
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...
# Verified sender address in your Resend domain
RESEND_FROM_EMAIL=noreply@your-domain.com

# --- Captcha Solver ---
# Supports 2captcha / anti-captcha compatible keys
API_KEY_SOLVER_CAPTCHA=

# --- Scraping Behaviour ---
REQUEST_TIMEOUT=30
MAX_RETRIES=3
# Base delay in seconds between requests (actual delay is randomised ± 50 %)
DELAY_BETWEEN_REQUESTS=2
