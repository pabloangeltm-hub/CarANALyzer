# ============================================================
# .env.example — copy to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Google (OAuth credentials live in credentials.json / token.json) ---
GOOGLE_SHEET_ID=
GOOGLE_SLIDES_ID=

# --- Proxy ---
# Format: http://user:password@host:port  or  socks5://host:port
PROXY_URL=

# --- Database ---
# Format: postgresql://user:password@host:port/dbname
DB_CONNECTION_STRING=

# --- Telegram Alerts ---
# Create a bot via @BotFather, get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Captcha Solver ---
# Supports 2captcha / anti-captcha compatible keys
API_KEY_SOLVER_CAPTCHA=

# --- Scraping Behaviour ---
REQUEST_TIMEOUT=30
MAX_RETRIES=3
# Base delay in seconds between requests (actual delay is randomised ± 50 %)
DELAY_BETWEEN_REQUESTS=2
